# ===========================================================================
# Mantle Alpha Agent - environment configuration
# Copy to `.env` and fill in secrets. NEVER commit your real `.env`.
# ===========================================================================

# ----------------------------------------------------------------- App
APP_NAME=Mantle Alpha Agent
ENVIRONMENT=development            # development | staging | production
DEBUG=true
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR | CRITICAL
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# ------------------------------------------------------------ Database
# In docker-compose the host is `db`; locally use `localhost`.
DATABASE_URL=postgresql+asyncpg://mantle:mantle@localhost:5432/mantle_alpha
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# --------------------------------------------------------------- Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------------------------------------------------------- Blockchain
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_WS_URL=
MANTLE_CHAIN_ID=5000
MANTLE_EXPLORER_URL=https://explorer.mantle.xyz
BLOCK_CONFIRMATIONS=1
BLOCK_POLL_INTERVAL=3.0
MAX_BLOCKS_PER_BATCH=50

# Optional on-chain alert logging (requires a deployed AlertLogger contract).
ENABLE_ONCHAIN_LOGGING=false
ALERT_LOGGER_CONTRACT_ADDRESS=
ALERT_LOGGER_PRIVATE_KEY=

# ----------------------------------------------------------------- AI
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=                    # required for LLM intent/insights; rule-based fallback works without it
OPENAI_BASE_URL=                   # optional: override for OpenAI-compatible endpoints
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_ALLOW_RULE_FALLBACK=true

# ------------------------------------------------------------ Telegram
TELEGRAM_BOT_TOKEN=                # get one from @BotFather
TELEGRAM_MODE=polling             # polling | webhook
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# ------------------------------------------------------------- Pricing
PRICE_PROVIDERS=coingecko,defillama
COINGECKO_API_KEY=
PRICE_CACHE_TTL_SECONDS=60
PRICE_STATIC_FALLBACK_ENABLED=true

# --------------------------------------------------------------- Rules
DEFAULT_WHALE_THRESHOLD_USD=10000
MIN_WHALE_THRESHOLD_USD=100
MAX_ALERTS_PER_USER=50

# ----------------------------------------------------------- Security
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
API_KEY=                           # optional: protects POST/DELETE REST endpoints
MAX_NL_INPUT_LENGTH=500
