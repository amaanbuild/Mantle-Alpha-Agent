# Private key (without 0x prefix is also accepted by most tooling, but 0x-prefixed is recommended)
# Used as the deployer and as the authorized writer for logAlert.
PRIVATE_KEY=

# RPC endpoint for Mantle Sepolia testnet (defaults to https://rpc.sepolia.mantle.xyz if unset)
MANTLE_TESTNET_RPC=

# RPC endpoint for Mantle mainnet (defaults to https://rpc.mantle.xyz if unset)
MANTLE_RPC=

# API key for the Mantle (Blockscout) explorer used during contract verification.
# Blockscout often accepts any non-empty value; leave blank or set as required.
MANTLE_EXPLORER_API_KEY=
